# URL of the deployed Hono API (no trailing slash).
# Leave empty in dev — Vite proxies /api to localhost:3001.
VITE_API_URL=

# ---- Supabase ---------------------------------------------------------------
# Real values are set by the project owner in the Supabase dashboard.
# These are baked in at build time, so changing them requires a rebuild.

# Project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Anon (public) key — safe to expose to the browser.
VITE_SUPABASE_ANON_KEY=
