# Port the API listens on. Railway sets PORT automatically.
PORT=3001

# Allowed CORS origin in production (your web service URL, no trailing slash).
# Leave unset to allow all origins (fine for local dev).
WEB_ORIGIN=

# ---- Supabase ---------------------------------------------------------------
# Real values are set by the project owner in the Supabase dashboard.
# Do not commit real keys.

# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Service-role (secret) key. Used by the service layer for DB access.
# Bypasses Row Level Security — keep it server-side only, never ship to the web app.
SUPABASE_SERVICE_ROLE_KEY=

# Project JWT secret (Settings → API → JWT Settings). Used by the auth
# middleware to verify Supabase-issued access tokens (HS256).
SUPABASE_JWT_SECRET=
