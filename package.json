{
  "name": "ai-test",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "dev": "pnpm build:shared && pnpm --parallel --filter @ai-test/shared --filter \"./apps/*\" dev",
    "dev:api": "pnpm build:shared && pnpm --filter api dev",
    "dev:web": "pnpm build:shared && pnpm --filter web dev",
    "build": "pnpm build:shared && pnpm --filter \"./apps/*\" build",
    "build:shared": "pnpm --filter @ai-test/shared build",
    "build:api": "pnpm build:shared && pnpm --filter api build",
    "build:web": "pnpm build:shared && pnpm --filter web build"
  }
}
